@{
    Layout = null;
    ViewData["Title"] = "Log Viewer";
    var lines = ViewBag.Lines as List<string> ?? new List<string>();
    int currentPage = ViewBag.CurrentPage != null ? (int)ViewBag.CurrentPage : 1;
    int totalPages = ViewBag.TotalPages != null ? (int)ViewBag.TotalPages : 1;
    int lineOffset = (currentPage - 1) * 500;
}

<style>
    @@import url('https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&display=swap');

    :root {
        --bg: #f5f5f5;
        --surface: #ffffff;
        --border: #e0e0e0;
        --text: #1a1a1a;
        --text-dim: #888;
        --accent: #2563eb;
        --line-bg: #f9f9f9;
        --ln-color: #bbb;
        /* log levels */
        --c-error: #dc2626;
        --c-warn: #d97706;
        --c-info: #1a1a1a;
        --c-debug: #9ca3af;
        --bg-error: #fff5f5;
        --bg-warn: #fffbeb;
    }

    [data-theme="dark"] {
        --bg: #111318;
        --surface: #13171f;
        --border: #1e2530;
        --text: #c8d4e0;
        --text-dim: #4a6070;
        --accent: #3b82f6;
        --line-bg: #0f1318;
        --ln-color: #2a3a4a;
        --c-error: #f87171;
        --c-warn: #fbbf24;
        --c-info: #c8d4e0;
        --c-debug: #4a6070;
        --bg-error: #1f1214;
        --bg-warn: #1c1810;
    }

    * {
        box-sizing: border-box;
        margin: 0;
        padding: 0;
    }

    body {
        background: var(--bg);
        color: var(--text);
        font-family: 'JetBrains Mono', monospace;
        font-size: 13px;
        height: 100vh;
        display: flex;
        flex-direction: column;
        overflow: hidden;
        transition: background 0.2s, color 0.2s;
    }

    /* Topbar */
    .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0 16px;
        height: 46px;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
        gap: 12px;
    }

    .topbar-left {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .back-link {
        color: var(--text-dim);
        text-decoration: none;
        font-size: 12px;
        flex-shrink: 0;
        transition: color 0.15s;
    }

        .back-link:hover {
            color: var(--text);
            text-decoration: none;
        }

    .file-title {
        font-size: 13px;
        font-weight: 500;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        color: var(--text);
    }

    .topbar-right {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-shrink: 0;
    }

    .btn-sm {
        background: transparent;
        border: 1px solid var(--border);
        color: var(--text-dim);
        font-family: 'JetBrains Mono', monospace;
        font-size: 11px;
        padding: 5px 11px;
        cursor: pointer;
        border-radius: 3px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 4px;
        transition: all 0.15s;
        white-space: nowrap;
    }

        .btn-sm:hover {
            border-color: var(--text-dim);
            color: var(--text);
            text-decoration: none;
        }

    .btn-live {
        border-color: #16a34a;
        color: #16a34a;
    }

        .btn-live:hover, .btn-live.on {
            background: #16a34a;
            color: #fff;
            border-color: #16a34a;
        }

    .theme-btn {
    }

    /* Filter bar */
    .filter-bar {
        display: flex;
        align-items: center;
        gap: 8px;
        padding: 8px 16px;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        flex-shrink: 0;
    }

    .filter-input {
        flex: 1;
        max-width: 320px;
        background: var(--bg);
        border: 1px solid var(--border);
        color: var(--text);
        font-family: 'JetBrains Mono', monospace;
        font-size: 12px;
        padding: 5px 10px;
        border-radius: 3px;
        outline: none;
        transition: border-color 0.15s;
    }

        .filter-input:focus {
            border-color: var(--accent);
        }

        .filter-input::placeholder {
            color: var(--text-dim);
        }

    .filter-stats {
        font-size: 11px;
        color: var(--text-dim);
    }

    /* Log area */
    .log-area {
        flex: 1;
        overflow-y: auto;
        overflow-x: auto;
        background: var(--surface);
    }

    .log-line {
        display: flex;
        align-items: flex-start;
        border-bottom: 1px solid var(--border);
        min-width: max-content;
    }

        .log-line:last-child {
            border-bottom: none;
        }

        .log-line.hidden {
            display: none;
        }

    .ln {
        flex-shrink: 0;
        width: 52px;
        padding: 4px 10px 4px 0;
        text-align: right;
        color: var(--ln-color);
        font-size: 11px;
        user-select: none;
        border-right: 1px solid var(--border);
        background: var(--line-bg);
    }

    .lt {
        padding: 4px 16px;
        white-space: pre;
        font-size: 12.5px;
        line-height: 1.6;
    }

    /* Levels */
    .lvl-error {
        background: var(--bg-error);
    }

        .lvl-error .lt {
            color: var(--c-error);
        }

    .lvl-warn {
        background: var(--bg-warn);
    }

        .lvl-warn .lt {
            color: var(--c-warn);
        }

    .lvl-info .lt {
        color: var(--c-info);
    }

    .lvl-debug .lt {
        color: var(--c-debug);
    }

    mark {
        background: rgba(251, 191, 36, 0.3);
        color: var(--c-warn);
        border-radius: 2px;
    }

    /* Footer */
    .footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 8px 16px;
        background: var(--surface);
        border-top: 1px solid var(--border);
        flex-shrink: 0;
        font-size: 11px;
        color: var(--text-dim);
    }

    .footer-right {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    /* Scrollbar */
    .log-area::-webkit-scrollbar {
        width: 5px;
        height: 5px;
    }

    .log-area::-webkit-scrollbar-track {
        background: var(--bg);
    }

    .log-area::-webkit-scrollbar-thumb {
        background: var(--border);
        border-radius: 3px;
    }
</style>

<div class="topbar">
    <div class="topbar-left">
        <a asp-action="Index" class="back-link">← Logs</a>
        <span class="file-title">@ViewBag.FileName</span>
    </div>
    <div class="topbar-right">
        <button id="liveBtn" class="btn-sm btn-live">◉ Live</button>
        <a asp-action="DownloadFile" asp-route-fileName="@ViewBag.FileName" class="btn-sm">↓ Download</a>
        <button class="btn-sm theme-btn" onclick="toggleTheme()" id="themeBtn">🌙</button>
    </div>
</div>

<div class="filter-bar">
    <input type="text" class="filter-input" id="filterInput" placeholder="Filter lines..." autocomplete="off" />
    <span class="filter-stats" id="filterStats"></span>
</div>

<div class="log-area" id="logArea">
    @{
        int ln = lineOffset;
    }
    @foreach (var line in lines)
    {
        ln++;
        var cls = "lvl-info";
        if (line.Contains("ERROR") || line.Contains("FATAL")) cls = "lvl-error";
        else if (line.Contains("WARN")) cls = "lvl-warn";
        else if (line.Contains("DEBUG") || line.Contains("TRACE")) cls = "lvl-debug";

        <div class="log-line @cls" data-t="@line.ToLower()">
            <span class="ln">@ln</span>
            <span class="lt">@line</span>
        </div>
    }
</div>

<div class="footer">
    <div>
        @if (currentPage > 1)
        {
            <a asp-action="ViewFile" asp-route-fileName="@ViewBag.FileName" asp-route-page="@(currentPage - 1)" class="btn-sm">← Prev</a>
        }
        &nbsp; Page @currentPage of @totalPages &nbsp;
        @if (currentPage < totalPages)
        {
            <a asp-action="ViewFile" asp-route-fileName="@ViewBag.FileName" asp-route-page="@(currentPage + 1)" class="btn-sm">Next →</a>
        }
    </div>
    <div class="footer-right">
        <span>@lines.Count lines</span>
        @{
            var errs = lines.Count(l => l.Contains("ERROR") || l.Contains("FATAL"));
            var warns = lines.Count(l => l.Contains("WARN"));
        }
        @if (errs > 0)
        {
            <span style="color:var(--c-error)">@errs errors</span>
        }
        @if (warns > 0)
        {
            <span style="color:var(--c-warn)">@warns warnings</span>
        }
    </div>
</div>

<script>
    // Theme
    const saved = localStorage.getItem('theme') || 'light';
    applyTheme(saved);

    function applyTheme(t) {
        document.documentElement.setAttribute('data-theme', t);
        document.getElementById('themeBtn').textContent = t === 'dark' ? '☀️' : '🌙';
    }

    function toggleTheme() {
        const cur = document.documentElement.getAttribute('data-theme') || 'light';
        const next = cur === 'dark' ? 'light' : 'dark';
        localStorage.setItem('theme', next);
        applyTheme(next);
    }

    // Filter
    const filterInput = document.getElementById('filterInput');
    const filterStats = document.getElementById('filterStats');
    const rows = document.querySelectorAll('.log-line');

    filterInput.addEventListener('input', function () {
        const q = this.value.trim().toLowerCase();
        let matches = 0;

        rows.forEach(row => {
            const txt = row.getAttribute('data-t') || '';
            const ltEl = row.querySelector('.lt');

            if (!q) {
                row.classList.remove('hidden');
                ltEl.textContent = ltEl.textContent; // reset
                return;
            }

            if (txt.includes(q)) {
                row.classList.remove('hidden');
                matches++;
            } else {
                row.classList.add('hidden');
            }
        });

        filterStats.textContent = q ? matches + ' matches' : '';
    });

    // Live tail
    let liveMode = false, liveInterval;
    const liveBtn = document.getElementById('liveBtn');

    liveBtn.addEventListener('click', function () {
        liveMode = !liveMode;
        this.classList.toggle('on', liveMode);
        this.textContent = liveMode ? '◉ Live ON' : '◉ Live';

        if (liveMode) {
            liveInterval = setInterval(() => location.reload(), 5000);
        } else {
            clearInterval(liveInterval);
        }
    });

    // Scroll to bottom
    const logArea = document.getElementById('logArea');
    logArea.scrollTop = logArea.scrollHeight;

    // Shortcut: / to focus filter
    document.addEventListener('keydown', e => {
        if (e.key === '/' && document.activeElement !== filterInput) {
            e.preventDefault();
            filterInput.focus();
        }
        if (e.key === 'Escape') {
            filterInput.value = '';
            filterInput.dispatchEvent(new Event('input'));
        }
    });
</script>
